{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/proxy/(.*)",
      "destination": "/api/proxy.js"
    },
    {
      "source": "/api/proxy",
      "destination": "/api/proxy.js"
    },
    {
      "source": "/api/scrape-stream",
      "destination": "/api/scrape-stream.js"
    }
  ],
  "functions": {
    "api/proxy.js": {
      "maxDuration": 30
    },
    "api/scrape-stream.js": {
      "maxDuration": 30
    }
  }
}